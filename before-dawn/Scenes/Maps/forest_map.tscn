[node name="NPC_Elenor" parent="." unique_id=1783511469 instance=ExtResource("20_7unj1")]
position = Vector2(366, 117)

[node name="DialogueInteraction" parent="NPC_Elenor" unique_id=836996665 instance=ExtResource("21_n7ij6")]
light_mask = 2

[node name="DialogueText" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=1067073133]
script = ExtResource("22_43gc4")
text = "..!? Varek! What happened? What's with all of that shouting!"
npc_name = "Elenor"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText2" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=138192917]
script = ExtResource("22_43gc4")
text = "The town found out I'm a vampire. I need to return home before they put me on a stake."
npc_name = "Varek"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText3" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=34553381]
script = ExtResource("22_43gc4")
text = "But the sun will rise soon... Will you manage to return home before dawn without being captured?"
npc_name = "Elenor"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText4" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=1050218822]
script = ExtResource("22_43gc4")
text = "Don't worry about me. I'll find a way. "
npc_name = "Varek"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText7" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=927009893]
script = ExtResource("22_43gc4")
text = "However, before I leave the forest I must find my amulet. I dropped it on my way to the city last night..."
npc_name = "Varek"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText5" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=1080009032]
script = ExtResource("22_43gc4")
text = "I'll buy you some time by distracting anyone I come across. Good luck, Varek. Stay safe..."
npc_name = "Elenor"
metadata/_custom_type_script = "uid://bsw880kyxeail"

[node name="DialogueText6" type="Node" parent="NPC_Elenor/DialogueInteraction" unique_id=532878174]
script = ExtResource("22_43gc4")
text = "Thanks, you too Ele."
npc_name = "Varek"
metadata/_custom_type_script = "uid://bsw880kyxeail"

