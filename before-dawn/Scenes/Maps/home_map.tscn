[sub_resource type="GDScript" id="GDScript_lb0wo"]
script/source = "extends ColorRect

func _ready():
	var shader_material = material as ShaderMaterial
	if shader_material:
		# Set the color palette
		var color_palette = [
			Color(0.05, 0.05, 0.15, 1.0),  # Night
			Color(0.1, 0.1, 0.35, 1.0),    # Dark blue
			Color(0.2, 0.3, 0.6, 1.0),     # Medium blue
			Color(0.4, 0.5, 0.8, 1.0),     # Light blue
			Color(0.8, 0.6, 0.7, 1.0),     # Light pink
			Color(0.9, 0.5, 0.6, 1.0),     # Medium pink
			Color(1.0, 0.6, 0.7, 1.0)      # Full dawn pink
		]
		
		for i in range(color_palette.size()):
			shader_material.set_shader_parameter(\"colors\", color_palette)

func start_dawn(duration: float = 5.0):
	var tween = create_tween()
	tween.tween_property(material, \"shader_parameter/dawn_progress\", 1.0, duration)
"

